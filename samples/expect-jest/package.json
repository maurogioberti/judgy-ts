{
  "name": "@judgy-ts/sample-expect-jest",
  "version": "0.1.0",
  "type": "module",
  "description": "Jest sample for Judgy TypeScript expect matchers.",
  "dependencies": {
    "@judgy-ts/core": "workspace:*",
    "@judgy-ts/expect": "workspace:*",
    "@judgy-ts/ollama": "workspace:*"
  },
  "devDependencies": {
    "jest": "^30.3.0"
  },
  "scripts": {
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
